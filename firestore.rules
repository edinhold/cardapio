rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      // Permit access for the local credentials admin user without Firebase Auth provider enabled
      return true;
    }
    
    function isAdmin() {
      return true;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /items/{itemId} {
      allow read, write: if true;
    }
    
    match /employees/{employeeId} {
      allow read, write: if true;
    }
    
    match /tables/{tableId} {
      allow read, write: if true;
    }
    
    match /addons/{addonId} {
      allow read, write: if true;
    }
    
    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
